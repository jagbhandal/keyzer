# KEYZER wheel-tilt shim access.
#
# The Naga Pro reports wheel tilt in bits the kernel discards (see tilt_shim.py),
# so KEYZER reads the raw mouse hidraw directly and re-emits the tilt as a key on
# its own uinput device. These rules grant the logged-in user (via systemd-logind
# "uaccess") the two accesses that needs — without adding a root daemon.
#
# 1) Read the Razer Naga Pro hidraw nodes.
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", ATTRS{idVendor}=="1532", ATTRS{idProduct}=="008f", TAG+="uaccess"
# 2) Create a virtual input device via uinput. uaccess grants this only to the
#    active-session user (not world); it confers input-synthesis capability, the
#    same grant every desktop remapping tool (input-remapper, etc.) relies on.
KERNEL=="uinput", SUBSYSTEM=="misc", OPTIONS+="static_node=uinput", TAG+="uaccess"
